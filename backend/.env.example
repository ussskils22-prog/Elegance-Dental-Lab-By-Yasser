PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/dental-system

# JWT
JWT_SECRET=change_this_to_a_secure_key_in_production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# Socket.io
SOCKET_IO_CORS=http://localhost:4200

# Logging
LOG_LEVEL=debug

# Demo users (after MongoDB is up): npm run seed — see scripts/seedUsers.js for emails/password.
